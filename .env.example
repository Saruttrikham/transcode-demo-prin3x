# Copy to .env: npm run env:init
#
# Local Node: MINIO_ENDPOINT=localhost is fine.
# Docker: compose.env sets MINIO to host.docker.internal; localhost in callbackUrl is rewritten inside the container. See README.md.
# Cloud Run: configure these in the console / secrets (no file in the image).

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
TRANSCODING_MAX_SOURCE_FILE_SIZE_BYTES=2147483648
TRANSCODE_TIMEOUT_MS=300000
# Optional callback webhook auth/version headers (outbound POST to callbackUrl):
CALLBACK_API_KEY=
CALLBACK_API_VERSION=1
# When set, POST /transcode requires header: X-Callback-Token: <same value>
TRANSCODE_INGRESS_TOKEN=
