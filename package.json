{
  "name": "@apps/transcoding-service",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "env:init": "node scripts/init-env.cjs",
    "docker:build": "docker build -t transcoding-service .",
    "docker:run": "docker run --rm -p 8080:8080 --env-file .env --env-file compose.env transcoding-service",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f transcoding"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "minio": "^8.0.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
